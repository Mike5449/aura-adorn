# -------------------------------------------------------------------
# Carat & Couleur — production .env
#
# Copy to .env on the server:   cp .env.example .env  &&  nano .env
# .env IS git-ignored. Never commit it.
# -------------------------------------------------------------------

# === Public-facing port for the web container ===
# The host's existing reverse proxy (nginx / Caddy) forwards
# boteakelegans.com → 127.0.0.1:WEB_PORT
WEB_PORT=8080

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=carat_couleur
DB_PORT=5433                # localhost-only, for psql admin

# === JWT ===
# Generate two distinct 64-char hex secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_hex
REFRESH_SECRET_KEY=CHANGE_ME_64_hex_different
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === CORS — origins allowed to call the API ===
# Add www.boteakelegans.com if you serve it too.
CORS_ORIGINS=https://boteakelegans.com,https://www.boteakelegans.com

# Trusted Host header — comma-separated, or `*` to allow any host
# (safe when there's a trusted reverse proxy in front, like our setup).
ALLOWED_HOSTS=*

# === Brute-force protection ===
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=15

# === MonCash (Digicel) ===
# Get from https://moncashbutton.digicelgroup.com
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
MONCASH_MODE=sandbox        # sandbox | production
MONCASH_RETURN_URL=https://boteakelegans.com/checkout/return

# === Delivery business rules ===
DELIVERY_FEE_HTG=150
FREE_DELIVERY_THRESHOLD_HTG=2500
DELIVERY_CITY_KEYWORD=delmas

# === Frontend build args ===
# Leave as /api unless you split the API on a different host.
VITE_API_URL=/api
